{
  "name": "@trapeza/adapter-gateway",
  "version": "0.0.0",
  "private": true,
  "description": "Circle Gateway / x402 settlement adapter for the Trapeza primitive. Wraps GatewayClient (client) and BatchFacilitatorClient (provider).",
